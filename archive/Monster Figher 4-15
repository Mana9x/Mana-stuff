            case "Assassin":    return "blade";
            case "Archer":      return "bow";
            case "Ranger":      return "bow";
            case "Mage":        return "staff";
            case "Sorcerer":    return "hands";
            case "Cleric":      return "mace";
            case "Shaman":      return "totem";
            case "Necromancer": return "staff";
            case "Druid":       return "claws";
            case "Bard":        return "instrument";
