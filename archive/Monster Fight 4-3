    public bool Execute()
    {
        string user = args["user"].ToString();
        string userId = args["userId"].ToString();
        string commandId = args["commandId"].ToString();

        bool monsterActive = CPH.GetGlobalVar<bool>("MonsterActive", true);
        if (!monsterActive)
        {
            CPH.SendMessage($"@{user}, there is no monster to fight right now!");
            CPH.CommandRemoveUserCooldown(commandId, userId, Platform.Twitch);
            return false;
        }

        string fighterList = CPH.GetGlobalVar<string>("MonsterFighters", true) ?? "";
        List<string> fighters = new List<string>(
            fighterList.Split(new char[] { ',' }, StringSplitOptions.RemoveEmptyEntries)
        );

        foreach (string entry in fighters)
        {
            string existingUser = entry.Split(':')[0];
            if (existingUser == user)
            {
                CPH.CommandRemoveUserCooldown(commandId, userId, Platform.Twitch);
                return false;
            }
        }

        string[] allRoles = { "Warrior", "Archer", "Mage", "Rogue", "Paladin", "Berserker", "Knight", "Ranger", "Shaman", "Necromancer", "Druid", "Bard", "Monk", "Assassin", "Cleric", "Sorcerer", "Summoner" };
        Random rng = new Random();
        string savedClass = CPH.GetTwitchUserVar<string>(user, "playerClass", true) ?? "";
        string role = allRoles[rng.Next(allRoles.Length)];
        foreach (string c in allRoles)
        {
            if (c.ToLower() == savedClass.ToLower())
            {
                role = c;
                break;
            }
        }

        fighters.Add($"{user}:{role}");
        CPH.SetGlobalVar("MonsterFighters", string.Join(",", fighters), true);

        string monsterName = CPH.GetGlobalVar<string>("ActiveMonsterName", true);
        bool windowOpen = CPH.GetGlobalVar<bool>("MonsterJoinWindowOpen", true);

        if (!windowOpen)
        {
            string firstMessage = GetFirstMessage(user, role, monsterName, rng);
            CPH.SetGlobalVar("MonsterJoinWindowOpen", true, true);
            CPH.SendMessage(firstMessage);
            CPH.EnableTimer("Monster Resolve Timer");
        }
        else
        {
            string joinMessage = GetJoinMessage(user, role, monsterName, rng);
            CPH.SendMessage(joinMessage);
        }

        return true;
    }

