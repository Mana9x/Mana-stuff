    private string GetGenericContributionLine(string user, string monsterName, Random rng)
    {
        string[] lines = {
            $"⚔️ @{user} fought hard against the {monsterName}!",
            $"⚔️ @{user} landed several hits on the {monsterName}!",
            $"⚔️ @{user} pressed the attack against the {monsterName}!",
            $"⚔️ @{user} dealt damage to the {monsterName}!",
            $"⚔️ @{user} battled the {monsterName} fiercely!"
        };
        return lines[rng.Next(lines.Length)];
    }
 
    private string GetGenericKillingBlowLine(string user, string monsterName, Random rng)
    {
        string[] lines = {
            $"⚔️ @{user} delivered the killing blow to the {monsterName}!",
